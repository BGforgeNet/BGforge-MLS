{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "packageManager": "pnpm",
    "testRunner": "vitest",
    "mutate": [
        "transpilers/*/src/**/*.ts",
        "!transpilers/*/src/**/*.test.ts"
    ],
    "checkers": ["typescript"],
    "tsconfigFile": "tsconfig.base.json",
    "coverageAnalysis": "perTest",
    "thresholds": {
        "high": 80,
        "low": 60,
        "break": null
    },
    "reporters": ["clear-text", "progress", "html"],
    "htmlReporter": {
        "fileName": "tmp/mutation/report.html"
    },
    "timeoutMS": 30000,
    "concurrency": 2
}
