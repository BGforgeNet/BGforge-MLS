{
    "name": "@bgforge/binary",
    "version": "3.7.0",
    "description": "Library and CLI for parsing and serialising Fallout PRO and MAP binary files (round-trip to canonical JSON snapshots).",
    "keywords": [
        "binary",
        "fallout",
        "map",
        "modding",
        "parser",
        "pro"
    ],
    "homepage": "https://github.com/BGforgeNet/BGforge-MLS",
    "bugs": {
        "url": "https://github.com/BGforgeNet/BGforge-MLS/issues"
    },
    "license": "SEE LICENSE IN LICENSE.txt",
    "author": "BGforge",
    "repository": {
        "type": "git",
        "url": "https://github.com/BGforgeNet/BGforge-MLS",
        "directory": "binary"
    },
    "bin": {
        "fgbin": "out/cli.js"
    },
    "files": [
        "out/",
        "!out/*.map",
        "README.md",
        "LICENSE.txt"
    ],
    "type": "module",
    "main": "out/index.js",
    "types": "out/index.d.ts",
    "exports": {
        ".": {
            "types": "./out/index.d.ts",
            "import": "./out/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown && chmod +x out/cli.js",
        "test": "vitest run --config vitest.config.ts"
    },
    "dependencies": {
        "cac": "^7.0.0",
        "diff": "^9.0.0",
        "typed-binary": "^4.3.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "tsdown": "^0.21.10",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=20"
    }
}
