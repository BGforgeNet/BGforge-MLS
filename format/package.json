{
    "name": "@bgforge/format",
    "version": "3.7.0",
    "description": "Library for formatting Fallout SSL, WeiDU BAF/D/TP2/TRA, Fallout MSG, Infinity Engine 2DA, and Fallout scripts.lst files",
    "keywords": [
        "fallout",
        "formatter",
        "infinity-engine",
        "modding",
        "weidu"
    ],
    "homepage": "https://github.com/BGforgeNet/BGforge-MLS",
    "bugs": {
        "url": "https://github.com/BGforgeNet/BGforge-MLS/issues"
    },
    "license": "SEE LICENSE IN LICENSE.txt",
    "author": "BGforge",
    "repository": {
        "type": "git",
        "url": "https://github.com/BGforgeNet/BGforge-MLS",
        "directory": "format"
    },
    "bin": {
        "fgfmt": "out/cli.js"
    },
    "files": [
        "out/",
        "!out/*.map",
        "README.md",
        "LICENSE.txt"
    ],
    "type": "module",
    "main": "out/index.js",
    "types": "out/index.d.ts",
    "exports": {
        ".": {
            "types": "./out/index.d.ts",
            "import": "./out/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup && chmod +x out/cli.js"
    },
    "dependencies": {
        "cac": "^7.0.0",
        "diff": "^9.0.0",
        "ini": "^6.0.0",
        "quick-lru": "^7.3.0",
        "web-tree-sitter": "^0.26.8"
    },
    "devDependencies": {
        "@types/ini": "^4.1.1",
        "tsup": "^8.3.0",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=20"
    }
}
