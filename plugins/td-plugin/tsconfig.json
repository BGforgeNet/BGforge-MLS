{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["es2022"],
        // TS Language Service plugins must use `export = init` (CommonJS module.exports).
        // verbatimModuleSyntax conflicts with `export =` in CommonJS modules, so it is
        // disabled here. module/moduleResolution are set to CommonJS for tsserver compatibility.
        "verbatimModuleSyntax": false,
        "module": "commonjs",
        "moduleResolution": "node",
        "allowImportingTsExtensions": true,
        "tsBuildInfoFile": "../../tmp/td-plugin.tsbuildinfo"
    },
    "include": ["src"],
    "exclude": ["test"]
}
