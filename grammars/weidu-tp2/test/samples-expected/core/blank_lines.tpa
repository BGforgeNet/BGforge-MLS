DEFINE_ACTION_MACRO ~ITEM_SPACING~ BEGIN
    OUTER_SET a = 1

    OUTER_SET b = 2

    OUTER_SET c = 3
END

DEFINE_ACTION_FUNCTION ~FN_SPACING~
    INT_VAR
        x = 0
BEGIN
    OUTER_SET y = 1

    OUTER_SET z = 2
END

ACTION_IF GAME_INCLUDES ~bg2~ BEGIN
    OUTER_SET first = 1

    OUTER_SET second = 2
END
