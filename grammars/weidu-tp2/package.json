{
    "name": "tree-sitter-weidu-tp2",
    "version": "0.1.0",
    "description": "WeiDU TP2 grammar for tree-sitter",
    "keywords": [
        "infinity-engine",
        "tree-sitter",
        "weidu",
        "weidu-tp2"
    ],
    "license": "MIT",
    "author": {
        "name": "BGforge",
        "email": "dev@bgforge.net",
        "url": "https://bgforge.net/"
    },
    "files": [
        "grammar.js",
        "tree-sitter.json",
        "src/**",
        "*.wasm",
        "queries/**"
    ],
    "type": "module",
    "scripts": {
        "build": "tree-sitter generate && tree-sitter build --wasm",
        "generate:types": "pnpm exec dts-tree-sitter . | sed 's/export const enum /export enum /' > src/tree-sitter.d.ts && cp src/tree-sitter.d.ts ../../server/src/weidu-tp2/tree-sitter.d.ts",
        "test": "../../scripts/test-grammar.sh weidu-tp2",
        "lint": "oxlint grammar.js",
        "playground": "tree-sitter playground"
    },
    "devDependencies": {
        "@asgerf/dts-tree-sitter": "^0.21.0"
    }
}
